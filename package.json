{
  "name": "hexmon-signage-api",
  "version": "1.0.0",
  "description": "Hexmon Signage - Production-Ready Digital Signage CMS Backend",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon",
    "dev:watch": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "db:push": "drizzle-kit push:pg",
    "db:generate": "drizzle-kit generate:pg",
    "db:studio": "drizzle-kit studio",
    "seed": "tsx scripts/seed.ts",
    "admin-cli": "tsx scripts/admin-cli.ts",
    "check": "tsx scripts/check-services.ts",
    "verify": "tsx scripts/verify-build.ts",
    "test:code": "tsx scripts/test-without-services.ts",
    "test:all": "npm run verify && npm run test:code"
  },
  "keywords": [
    "signage",
    "cms",
    "digital-signage",
    "fastify"
  ],
  "author": "Hexmon",
  "license": "MIT",
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^2.2.0",
    "@aws-sdk/client-s3": "^3.500.0",
    "@aws-sdk/s3-request-presigner": "^3.922.0",
    "@casl/ability": "^6.5.0",
    "@fastify/cors": "^8.5.0",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^1.10.1",
    "argon2": "^0.44.0",
    "csv-stringify": "^6.6.0",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.29.1",
    "fastify": "^4.25.2",
    "fluent-ffmpeg": "^2.1.3",
    "jose": "^5.2.0",
    "pg": "^8.11.3",
    "pg-boss": "^10.0.1",
    "pino": "^8.17.2",
    "pino-http": "^8.6.1",
    "prom-client": "^15.0.0",
    "socket.io": "^4.7.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.11.0",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "@vitest/coverage-v8": "^1.1.0",
    "drizzle-kit": "^0.20.14",
    "eslint": "^8.56.0",
    "nodemon": "^3.1.10",
    "pino-pretty": "^10.3.1",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3",
    "tsc-alias": "^1.8.8",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
