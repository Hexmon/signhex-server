# Server
NODE_ENV=development
HOST=0.0.0.0
PORT=3000

# Docker published ports / container names
API_HOST_PORT=3000
API_CONTAINER_NAME=hexmon-api

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=signhex
POSTGRES_HOST_PORT=5432
POSTGRES_CONTAINER_NAME=hexmon-postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/signhex

# JWT
JWT_SECRET=your-secret-key-min-32-chars-long-here
JWT_EXPIRY=900

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_HOST_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_CONTAINER_NAME=hexmon-minio
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_REGION=us-east-1

# Admin User (seed)
ADMIN_EMAIL=admin@hexmon.local
ADMIN_PASSWORD=ChangeMe123!

# Pairing CA
CA_CERT_PATH=./certs/ca.crt

# Legacy / incomplete dedicated device TLS listener settings.
# The current supported runtime exposes the backend on PORT only.
# DEVICE_PORT=8443
# DEVICE_HOST_PORT=8443
# TLS_CERT_PATH=./certs/server.crt
# TLS_KEY_PATH=./certs/server.key

# Logging
LOG_LEVEL=info
ENABLE_SWAGGER_UI=true

# Runtime tools
FFMPEG_PATH=ffmpeg
LIBREOFFICE_PATH=soffice
PG_DUMP_PATH=pg_dump
TAR_PATH=tar
# HEXMON_WEBPAGE_CAPTURE_EXECUTABLE_PATH=

# pg-boss
PG_BOSS_SCHEMA=pgboss

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=1000
RATE_LIMIT_TIME_WINDOW=1 minute

# CORS / Socket.IO
CORS_ORIGINS=http://localhost:8080
SOCKET_ALLOWED_ORIGINS=http://localhost:8080
APP_PUBLIC_BASE_URL=http://localhost:8080

# Optional Redis (future distributed chat rate limiter)
# REDIS_URL=redis://localhost:6379
