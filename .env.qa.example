NODE_ENV=development
HOST=0.0.0.0
PORT=3000
DEVICE_PORT=8443

API_HOST_PORT=3000
API_CONTAINER_NAME=hexmon-api

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=signhex
POSTGRES_HOST_PORT=5432
POSTGRES_CONTAINER_NAME=hexmon-postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/signhex

JWT_SECRET=replace-this-with-a-secret-at-least-32-characters
JWT_EXPIRY=900

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_HOST_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_CONTAINER_NAME=hexmon-minio
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_REGION=us-east-1

ADMIN_EMAIL=admin@hexmon.local
ADMIN_PASSWORD=ChangeMe123!

TLS_CERT_PATH=./certs/server.crt
TLS_KEY_PATH=./certs/server.key
CA_CERT_PATH=./certs/ca.crt

LOG_LEVEL=info
ENABLE_SWAGGER_UI=true

FFMPEG_PATH=ffmpeg
LIBREOFFICE_PATH=soffice
PG_DUMP_PATH=pg_dump
TAR_PATH=tar

PG_BOSS_SCHEMA=pgboss

RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=1000
RATE_LIMIT_TIME_WINDOW=1 minute

CORS_ORIGINS=http://192.168.0.11:8080,http://localhost:8080
SOCKET_ALLOWED_ORIGINS=http://192.168.0.11:8080,http://localhost:8080
APP_PUBLIC_BASE_URL=http://192.168.0.11:8080
CSRF_ENABLED=true

PASSWORD_MIN_LENGTH=12
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_WINDOW_SECONDS=900

MAX_UPLOAD_MB=200
STORAGE_QUOTA_BYTES=0

OBSERVABILITY_METRICS_ENABLED=true
OBSERVABILITY_METRICS_BEARER_TOKEN=signhex-development-prometheus
OBSERVABILITY_DEPLOYMENT_MODE=qa
OBSERVABILITY_PROMETHEUS_BASE_URL=http://127.0.0.1:9090
OBSERVABILITY_PROMETHEUS_TIMEOUT_MS=1500
OBSERVABILITY_GRAFANA_ENABLED=true
OBSERVABILITY_GRAFANA_EMBED_ENABLED=true
OBSERVABILITY_GRAFANA_BASE_PATH=/grafana
